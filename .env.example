# 네이버 검색 API (앱: stocknews)
# https://developers.naver.com 에서 발급
NAVER_CLIENT_ID=your_client_id_here
NAVER_CLIENT_SECRET=your_client_secret_here

# 한국투자증권(KIS) Open API
# https://apiportal.koreainvestment.com 에서 발급
KIS_APP_KEY=your_kis_app_key_here
KIS_APP_SECRET=your_kis_app_secret_here
KIS_CANO=your_account_number_here
KIS_ACNT_PRDT_CD=01
KIS_ENV=real

# 익일 투자주의 미리보기 전용 Upstash Redis (자동매매 KV와 반드시 별도 생성)
# Mac 실행기에는 쓰기 토큰, Vercel에는 동일 URL + READ_ONLY 토큰만 설정한다.
RADAR_PREVIEW_KV_REST_API_URL=https://your-preview-kv.upstash.io
RADAR_PREVIEW_KV_REST_API_TOKEN=your_preview_write_token
# Vercel 전용:
# RADAR_PREVIEW_KV_REST_API_READ_ONLY_TOKEN=your_preview_read_only_token
